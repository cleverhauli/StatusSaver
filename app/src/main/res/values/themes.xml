<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.WAStatusSaver" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash theme required by Jetpack SplashScreen API -->
    <style name="Theme.WAStatusSaver.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#111B21</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.WAStatusSaver</item>
    </style>
</resources>